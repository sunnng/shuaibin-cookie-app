{
  "name": "shuaibin-cookie-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.28",
      "@orpc/server": "^1.14.6",
      "@orpc/openapi": "^1.14.6",
      "@orpc/zod": "^1.14.6",
      "lucide-react": "^1.21.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@orpc/client": "^1.14.6",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @shuaibin-cookie-app/db",
    "db:studio": "turbo run db:studio -F @shuaibin-cookie-app/db",
    "db:generate": "turbo run db:generate -F @shuaibin-cookie-app/db",
    "db:migrate": "turbo run db:migrate -F @shuaibin-cookie-app/db",
    "db:local": "turbo run db:local -F @shuaibin-cookie-app/db",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@shuaibin-cookie-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@shuaibin-cookie-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.14"
}
